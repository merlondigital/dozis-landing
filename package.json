    "lucide-react": "^0.500",
    "next": "^15.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4",
    "tailwind-merge": "^3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
